# 법제처 Open API — https://open.law.go.kr 에서 OC 코드 발급
LAW_API_KEY=your-law-api-oc-code
LAW_API_BASE_URL=http://www.law.go.kr/DRF

# Groq API — https://console.groq.com/keys 에서 무료 API 키 발급
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# 무료 티어 일일 요청 한도 여유 컷오프 — console.groq.com/settings/limits 에서 실제
# 한도를 확인해 필요 시 조정. 기본값은 조사 시점 기준 llama-3.3-70b-versatile RPD(1,000)의 90%.
GROQ_DAILY_REQUEST_LIMIT=1000
GROQ_USAGE_WARN_RATIO=0.9

# 임베딩 모델 (로컬, sentence-transformers)
EMBEDDING_MODEL=jhgan/ko-sroberta-multitask
